{
  "name": "nati-beniyas-speedy-adventure",
  "private": true,
  "version": "1.15.1",
  "type": "module",
  "description": "A browser platform-adventure game built with Phaser 3.",
  "scripts": {
    "build": "esbuild 2d/js/main.js --bundle --outfile=2d/dist/bundle.js --target=es2017 --format=iife",
    "build:3d": "esbuild game3d/js/main.js --bundle --outfile=game3d/dist/bundle.js --target=es2020 --format=esm --loader:.wasm=file --asset-names=[name]"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "playwright": "^1.61.1"
  },
  "dependencies": {
    "@babylonjs/core": "^9.16.1",
    "@babylonjs/havok": "^1.3.13",
    "@babylonjs/loaders": "^9.16.1"
  }
}
